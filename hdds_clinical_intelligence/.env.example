# Copy this file to .env and fill in the values you have.
# EVERY key is optional: with none set, the app runs fully offline using
# rule-based agents and the keyword RAG fallback.

# --- Azure OpenAI (primary on the company laptop / Azure deployment) ---
# Powers the chat agent and the Azure RAG backup. Use the *deployment names*
# you created in Azure OpenAI Studio, not the base model names.
AZURE_OPENAI_ENDPOINT=""              # https://<resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_API_VERSION="2024-06-01"
AZURE_OPENAI_CHAT_DEPLOYMENT=""       # e.g. gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=""  # e.g. text-embedding-3-small

# --- RAG backend selection ---
# auto (default) = try EY GDX, then Azure RAG, then keyword fallback.
# Force one with: gdx | azure | keyword
RAG_BACKEND="auto"

# --- Azure Text Analytics for Health (optional entity extraction) ---
AZURE_LANGUAGE_ENDPOINT=""
AZURE_LANGUAGE_KEY=""

# --- Gemini (optional chat fallback if Azure OpenAI is not set) ---
GEMINI_API_KEY=""

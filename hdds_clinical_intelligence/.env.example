# Copy this file to .env and fill in the values you have.
# EVERY key is optional: with none set, the app runs fully offline using
# rule-based agents and the keyword RAG fallback.

# --- Azure OpenAI (primary on the company laptop / Azure deployment) ---
# Powers the chat agent and the Azure RAG backup. Use the *deployment names*
# you created in Azure OpenAI Studio, not the base model names.
AZURE_OPENAI_ENDPOINT=""              # https://<resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_API_VERSION="2024-06-01"
AZURE_OPENAI_CHAT_DEPLOYMENT=""       # e.g. gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=""  # e.g. text-embedding-3-small

# --- RAG backend selection ---
# auto (default) = try EY GDX, then Azure RAG, then keyword fallback.
# Force one with: gdx | azure | keyword
RAG_BACKEND="auto"

# --- Auth (JWT) ---
# Generate a strong secret:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=""
JWT_EXPIRE_MINUTES="60"

# --- API server / CORS ---
# Comma-separated list of allowed frontend origins (no trailing slash).
# In prod set to your deployed frontend, e.g. https://<app>.azurestaticapps.net
ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
MAX_UPLOAD_MB="25"                     # reject uploads larger than this

# --- Azure Text Analytics for Health (entity extraction from uploaded docs) ---
AZURE_LANGUAGE_ENDPOINT=""
AZURE_LANGUAGE_KEY=""

# --- Azure Document Intelligence (OCR for faxes & handwritten notes) ---
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=""
AZURE_DOCUMENT_INTELLIGENCE_KEY=""

# --- Azure Health Insights (Radiology Insights for X-Ray/CT analysis) ---
# Note: Sometimes this uses the same endpoint/key as Text Analytics for Health, but often it has its own resource.
AZURE_HEALTH_INSIGHTS_ENDPOINT=""
AZURE_HEALTH_INSIGHTS_KEY=""

# --- Azure AI Speech (dictation -> text for /api/dictate) ---
AZURE_SPEECH_KEY=""
AZURE_SPEECH_REGION=""                 # e.g. eastus

# --- Azure Blob Storage (datasets, uploads, generated outputs) ---
# When unset, the app transparently uses local files only.
# Prefer Managed Identity in production; a connection string is fine for prototyping.
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER_RAW="hdds-raw-data"      # synthetic source datasets
AZURE_STORAGE_CONTAINER_UPLOADS="hdds-uploads"   # uploaded docs (treat as PHI)
AZURE_STORAGE_CONTAINER_OUTPUTS="hdds-outputs"   # generated insights

# --- Gemini (optional chat fallback if Azure OpenAI is not set) ---
GEMINI_API_KEY=""
